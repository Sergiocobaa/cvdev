generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Analysis {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  cvText           String
  jobDescription   String
  score            Int
  scoreExplanation String
  improvements     String
  coverLetter      String
}
